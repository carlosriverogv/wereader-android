<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/preferences_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Theme -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:text="Theme"
        android:textColor="?android:attr/textColorPrimary"
        android:textStyle="bold" />

    <RadioGroup
        android:id="@+id/themeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/theme_light"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackground"
            android:button="@drawable/theme_light_selector"
            android:checked="false"
            android:contentDescription="Light theme" />

        <RadioButton
            android:id="@+id/theme_dark"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackground"
            android:button="@drawable/theme_dark_selector"
            android:contentDescription="Dark theme" />

        <RadioButton
            android:id="@+id/theme_sepia"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="?android:selectableItemBackground"
            android:button="@drawable/theme_sepia_selector"
            android:contentDescription="Sepia theme" />

        <!--<ImageButton
            android:id="@+id/theme_more"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="More themes"
            android:src="@drawable/baseline_more_horiz_24"
            android:tint="@android:color/white" />-->
    </RadioGroup>

    <!-- Text size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingTop="16dp">

        <com.google.android.material.slider.Slider
            android:id="@+id/textSizeSlider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:valueFrom="0.8"
            android:valueTo="2.0"
            android:stepSize="0.1"
            app:haloColor="@color/light_accentColor"/>

        <!--<ImageButton
            android:id="@+id/textSizeMinus"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
